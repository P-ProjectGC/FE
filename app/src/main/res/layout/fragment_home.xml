<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeFragment">

    <!-- 전체 스크롤 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 스크롤 내부는 단 하나의 LinearLayout -->
        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="56dp"
            android:paddingBottom="200dp">

            <!-- 인삿말 -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="“남유정”의\nPlanGo"
                android:textColor="#222222"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="130dp" />

            <!-- 검색창 -->
            <LinearLayout
                android:id="@+id/layout_search"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="70dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_search">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여행방 검색"
                    android:textColor="#8FA1B1"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 스크롤 힌트 -->
            <TextView
                android:id="@+id/tv_scroll_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="아래로 스크롤하세요"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="180dp"
                android:layout_marginBottom="70dp"/>

            <!-- 캘린더 카드 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/calendarCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="#FFFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 월 이동 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/btn_prev_month"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_left" />

                        <TextView
                            android:id="@+id/tv_month"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2025년 10월"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginHorizontal="16dp" />

                        <ImageView
                            android:id="@+id/btn_next_month"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_right" />
                    </LinearLayout>

                    <!-- 요일 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="12dp">

                        <TextView android:text="일" style="@style/CalendarWeek" />
                        <TextView android:text="월" style="@style/CalendarWeek" />
                        <TextView android:text="화" style="@style/CalendarWeek" />
                        <TextView android:text="수" style="@style/CalendarWeek" />
                        <TextView android:text="목" style="@style/CalendarWeek" />
                        <TextView android:text="금" style="@style/CalendarWeek" />
                        <TextView android:text="토" style="@style/CalendarWeek" />
                    </LinearLayout>

                    <!-- 날짜 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_calendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tv_selected_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="날짜를 선택해주세요"
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp"/>

                    <Button
                        android:id="@+id/btn_create_trip"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="새로운 여행 만들기"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:background="@drawable/bg_button_blue"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
