<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🔵 그림자 (피그마 Drop Shadow 재현) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20000000"/> <!-- 12% 블랙 그림자 -->
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- ⚪ 반투명 흰색 배경 + 파란 테두리 -->
    <item android:left="0dp" android:top="4dp" android:right="0dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#F2FFFFFF"/> <!-- 흰색 95% -->
            <stroke android:width="2dp" android:color="#4DA8DEF5"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

</layer-list>
